# Server
SERVER_ADDR=:8080

# MySQL
MYSQL_DSN=remail:remail@tcp(127.0.0.1:3306)/remail?charset=utf8mb4&parseTime=True&loc=Local

# Redis
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0

# MinIO
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=remail
MINIO_SECRET_KEY=remail_secret
MINIO_USE_SSL=false
MINIO_BUCKET=remail

# SMTP outbound mail
SMTP_ADDR=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# Migrations
MIGRATIONS_DIR=

# Session
SESSION_SECRET=change-me-in-production
SESSION_MAX_AGE=86400
SESSION_SECURE=false

# Log
LOG_LEVEL=info
LOG_FORMAT=json

# Diagnostics
# Leave empty to disable. Set to 127.0.0.1:6060 for local pprof.
PPROF_ADDR=
