# Server
SERVER_ADDR=:8080
TRUSTED_PROXIES=127.0.0.1,::1

# MySQL
MYSQL_DSN=remail:remail@tcp(127.0.0.1:3306)/remail?charset=utf8mb4&parseTime=True&loc=Local

# Redis
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0

# MinIO
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=remail
MINIO_SECRET_KEY=remail_secret
MINIO_USE_SSL=false
MINIO_BUCKET=remail

# SMTP outbound mail
SMTP_ADDR=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# Migrations
MIGRATIONS_DIR=

# Session
SESSION_SECRET=change-me-in-production
SESSION_MAX_AGE=86400
SESSION_SECURE=false

# Cloudflare Turnstile (official always-pass test keys; replace both in production)
TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Log
LOG_LEVEL=info
LOG_FORMAT=json

# Diagnostics
# Leave empty to disable pprof. For local binary use 127.0.0.1:6060; for Docker use :6060.
PPROF_ADDR=
SLOW_REQUEST_THRESHOLD=1s
SLOW_SQL_THRESHOLD=200ms
PPROF_CPU_THRESHOLD=80
PPROF_CPU_PROFILE_DIR=pprof
PPROF_CPU_PROFILE_DURATION=10s
PPROF_CPU_CHECK_INTERVAL=30s
