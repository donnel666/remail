{
  "name": "remail-console",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "packageManager": "pnpm@10.25.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "core-js"
    ]
  },
  "scripts": {
    "dev": "rsbuild dev",
    "build": "pnpm generate:public-openapi && rsbuild build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "generate:api": "openapi-typescript ../api/openapi.yaml -o src/lib/openapi/schema.ts",
    "generate:public-openapi": "node scripts/generate-public-openapi.mjs"
  },
  "dependencies": {
    "@douyinfe/semi-icons": "2.100.0",
    "@douyinfe/semi-illustrations": "2.100.0",
    "@douyinfe/semi-ui": "2.100.0",
    "@tanstack/react-router": "^1.114.0",
    "clsx": "^2.1.1",
    "i18next": "^26.3.3",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^0.488.0",
    "openapi-fetch": "^0.17.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^17.0.8",
    "react-icons": "^5.7.0",
    "tailwind-merge": "^3.6.0",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@rsbuild/core": "^1.3.0",
    "@rsbuild/plugin-react": "^1.1.0",
    "@tailwindcss/postcss": "^4.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "https-proxy-agent": "^9.1.0",
    "jsdom": "^29.1.1",
    "openapi-typescript": "^7.13.0",
    "swagger-ui-dist": "^5.32.8",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.10"
  }
}
